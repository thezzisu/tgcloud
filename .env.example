# tgcloud configuration — copy to .env and edit

# Panel admin credentials (only used on first start when no accounts.json exists)
TGCLOUD_USER=admin
TGCLOUD_PASSWORD=changeme

# Image version tag
TGCLOUD_VERSION=latest

# Image registry prefix
TGCLOUD_IMAGE_PREFIX=git.pku.edu.cn/thezzisu

# User/group ID for volume permissions
TGCLOUD_PUID=1000
TGCLOUD_PGID=1000

# Timezone
TGCLOUD_TZ=Asia/Shanghai

# Panel HTTP port on host
TGCLOUD_HTTP_PORT=36080

# Video devices for camera passthrough (comma-separated, optional)
TGCLOUD_VIDEO_DEVICES=

# --- ptrace for tg key extraction ---
# Option A (recommended): set on host:
#   echo 0 | sudo tee /proc/sys/kernel/yama/ptrace_scope
# Option B: uncomment below to add CAP_SYS_PTRACE to instance containers
#   (requires patching panel docker.ts — see docs/design.md)
# TGCLOUD_PTRACE_CAP=1
